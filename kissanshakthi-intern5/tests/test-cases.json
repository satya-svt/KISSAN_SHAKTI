{
  "_meta": {
    "description": "Day 9 Deliverable — 20 mock test cases for KissanShakthi AI Intent Parser accuracy evaluation",
    "intern": "Intern 5 — AI Intent Parser",
    "total_cases": 20,
    "intent_distribution": {
      "POST_JOB": 5,
      "SEARCH_WORKERS": 3,
      "REGISTER_WORKER": 2,
      "NAVIGATE": 3,
      "ADVISORY": 2,
      "EQUIPMENT_RENT": 2,
      "VIEW_LISTINGS": 1,
      "CHECK_STATUS": 1,
      "UNKNOWN": 1
    }
  },

  "test_cases": [
    {
      "id": "TC-001",
      "category": "POST_JOB — Full Data",
      "input": "I need 8 workers for wheat harvest starting July 10 near Nashik, will pay 400 rupees per day for 5 days",
      "expected_intent": "POST_JOB",
      "expected_confidence_min": 0.85,
      "expected_variables": {
        "crop_type": "wheat",
        "worker_count": 8,
        "location": "Nashik",
        "wage_per_day": 400,
        "duration_days": 5
      },
      "expected_fallback_triggered": false,
      "notes": "Clean English input with all critical fields"
    },
    {
      "id": "TC-002",
      "category": "POST_JOB — Hinglish",
      "input": "mujhe 5 mazdoor chahiye gehu ki fasal ke liye, Pune ke paas, 15 July se",
      "expected_intent": "POST_JOB",
      "expected_confidence_min": 0.80,
      "expected_variables": {
        "crop_type": "wheat",
        "worker_count": 5,
        "location": "near Pune"
      },
      "expected_fallback_triggered": false,
      "notes": "Hinglish input — gehu=wheat, mazdoor=worker, chahiye=need"
    },
    {
      "id": "TC-003",
      "category": "POST_JOB — Partial Data",
      "input": "need workers for rice harvest",
      "expected_intent": "POST_JOB",
      "expected_confidence_min": 0.65,
      "expected_variables": {
        "crop_type": "rice",
        "worker_count": null,
        "location": null,
        "start_date": null
      },
      "expected_fallback_triggered": true,
      "expected_missing_fields": ["worker_count", "location"],
      "notes": "Partial input — fallback should trigger asking for count and location"
    },
    {
      "id": "TC-004",
      "category": "POST_JOB — Self-Correction",
      "input": "I need... no wait... 10 workers, not 5, 10 workers for sugarcane near Kolhapur",
      "expected_intent": "POST_JOB",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "crop_type": "sugarcane",
        "worker_count": 10,
        "location": "Kolhapur"
      },
      "expected_fallback_triggered": false,
      "notes": "Self-correction — should use last stated value (10, not 5)"
    },
    {
      "id": "TC-005",
      "category": "POST_JOB — Regional Transliteration",
      "input": "ganna katne ke liye 12 log chahiye, Solapur mein, 400 roz",
      "expected_intent": "POST_JOB",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "crop_type": "sugarcane",
        "worker_count": 12,
        "location": "Solapur",
        "wage_per_day": 400
      },
      "expected_fallback_triggered": false,
      "notes": "ganna=sugarcane, roz=per day — regional transliteration test"
    },
    {
      "id": "TC-006",
      "category": "SEARCH_WORKERS — Location Based",
      "input": "show me available workers near Aurangabad for soybean",
      "expected_intent": "SEARCH_WORKERS",
      "expected_confidence_min": 0.85,
      "expected_variables": {
        "location": "Aurangabad",
        "crop_type": "soybean"
      },
      "expected_fallback_triggered": false,
      "notes": "Clean search with location and crop filter"
    },
    {
      "id": "TC-007",
      "category": "SEARCH_WORKERS — Hinglish",
      "input": "Nashik ke paas kaun mazdoor available hai",
      "expected_intent": "SEARCH_WORKERS",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "location": "Nashik"
      },
      "expected_fallback_triggered": false,
      "notes": "Hinglish worker search"
    },
    {
      "id": "TC-008",
      "category": "SEARCH_WORKERS — No Location",
      "input": "find me some workers",
      "expected_intent": "SEARCH_WORKERS",
      "expected_confidence_min": 0.60,
      "expected_variables": {
        "location": null
      },
      "expected_fallback_triggered": true,
      "expected_missing_fields": ["location"],
      "notes": "SEARCH_WORKERS with no location — must trigger fallback"
    },
    {
      "id": "TC-009",
      "category": "REGISTER_WORKER — English",
      "input": "I am a farm worker and want to register for jobs",
      "expected_intent": "REGISTER_WORKER",
      "expected_confidence_min": 0.85,
      "expected_fallback_triggered": false,
      "notes": "Clear worker registration intent"
    },
    {
      "id": "TC-010",
      "category": "REGISTER_WORKER — Hinglish",
      "input": "mujhe mazdoor ke roop mein register karna hai, main tractor operator hoon",
      "expected_intent": "REGISTER_WORKER",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "worker_skill": "tractor_operator"
      },
      "expected_fallback_triggered": false,
      "notes": "Registration with skill specification"
    },
    {
      "id": "TC-011",
      "category": "NAVIGATE — Worker List",
      "input": "take me to the worker list page",
      "expected_intent": "NAVIGATE",
      "expected_confidence_min": 0.90,
      "expected_variables": {
        "navigate_target": "worker_list"
      },
      "expected_screen": "/workers",
      "expected_fallback_triggered": false,
      "notes": "Explicit navigation to worker list"
    },
    {
      "id": "TC-012",
      "category": "NAVIGATE — Job Board",
      "input": "job board dikhaao",
      "expected_intent": "NAVIGATE",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "navigate_target": "job_board"
      },
      "expected_screen": "/jobs",
      "expected_fallback_triggered": false,
      "notes": "Hinglish navigation to job board"
    },
    {
      "id": "TC-013",
      "category": "NAVIGATE — Home",
      "input": "go back to home page",
      "expected_intent": "NAVIGATE",
      "expected_confidence_min": 0.90,
      "expected_variables": {
        "navigate_target": "home"
      },
      "expected_screen": "/",
      "expected_fallback_triggered": false,
      "notes": "Navigation to home screen"
    },
    {
      "id": "TC-014",
      "category": "ADVISORY — Crop Advice",
      "input": "what is the best time to plant onion in Maharashtra?",
      "expected_intent": "ADVISORY",
      "expected_confidence_min": 0.85,
      "expected_variables": {
        "crop_type": "onion",
        "location": "Maharashtra"
      },
      "expected_fallback_triggered": false,
      "notes": "Farming advisory with crop and location"
    },
    {
      "id": "TC-015",
      "category": "ADVISORY — Pest Problem",
      "input": "meri fasal mein keede lag rahe hain, kya karoon",
      "expected_intent": "ADVISORY",
      "expected_confidence_min": 0.75,
      "expected_fallback_triggered": false,
      "notes": "Pest problem advisory in Hinglish"
    },
    {
      "id": "TC-016",
      "category": "EQUIPMENT_RENT — Tractor",
      "input": "I need to rent a tractor for 3 days near Latur",
      "expected_intent": "EQUIPMENT_RENT",
      "expected_confidence_min": 0.85,
      "expected_variables": {
        "equipment_type": "tractor",
        "duration_days": 3,
        "location": "Latur"
      },
      "expected_fallback_triggered": false,
      "notes": "Equipment rental with duration and location"
    },
    {
      "id": "TC-017",
      "category": "EQUIPMENT_RENT — Hinglish",
      "input": "combine harvester kiraye pe chahiye",
      "expected_intent": "EQUIPMENT_RENT",
      "expected_confidence_min": 0.75,
      "expected_variables": {
        "equipment_type": "combine harvester"
      },
      "expected_fallback_triggered": false,
      "notes": "Equipment rental in Hinglish"
    },
    {
      "id": "TC-018",
      "category": "VIEW_LISTINGS",
      "input": "show me all available job listings",
      "expected_intent": "VIEW_LISTINGS",
      "expected_confidence_min": 0.85,
      "expected_fallback_triggered": false,
      "notes": "Simple view listings intent"
    },
    {
      "id": "TC-019",
      "category": "CHECK_STATUS",
      "input": "did anyone apply to my job posting?",
      "expected_intent": "CHECK_STATUS",
      "expected_confidence_min": 0.80,
      "expected_fallback_triggered": false,
      "notes": "Status check on a job posting"
    },
    {
      "id": "TC-020",
      "category": "UNKNOWN — Noise",
      "input": "umm... haan... nahi...",
      "expected_intent": "UNKNOWN",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3,
      "expected_fallback_triggered": true,
      "notes": "Noise/filler input — immediate fallback without API call"
    }
  ]
}
