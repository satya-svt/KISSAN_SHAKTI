  "fallback_route": {
    "screen": "/",
    "label": "Home (default fallback)",
    "description": "If no route matches and intent is UNKNOWN or NAVIGATE with null target, redirect to home"
  },

  "prefill_field_map": {
    "description": "Maps parser variable keys to Intern 1's React form state field names. Intern 1 must maintain this contract.",
    "mapping": {
      "crop_type": "cropType",
      "worker_count": "workersNeeded",
      "start_date": "startDate",
      "end_date": "endDate",
      "duration_days": "durationDays",
      "location": "location",
      "wage_per_day": "wagePerDay",
      "worker_skill": "workerSkill",
      "equipment_type": "equipmentType",
      "query_text": "searchQuery"
    }
  }
}
