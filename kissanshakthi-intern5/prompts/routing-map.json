{
  "_meta": {
    "version": "1.0.0",
    "description": "Day 6–7 Deliverable. Voice command → UI screen routing map for KissanShakthi. Used by intent-parser.js to resolve navigate_target to screen routes.",
    "intern": "Intern 5 — AI Intent Parser",
    "coordinates_with": "Intern 1 (Frontend UI) — React Router paths must match these screen values"
  },

  "routes": {
    "home": {
      "screen": "/",
      "label": "Home / Main Menu",
      "trigger_phrases": [
        "home", "main menu", "go home", "back to start", "shuru mein jaao",
        "main page", "dashboard", "ghar", "pehla page"
      ]
    },
    "worker_list": {
      "screen": "/workers",
      "label": "Worker Listings",
      "trigger_phrases": [
        "show workers", "worker list", "available workers", "labourers near me",
        "find workers", "mazdoor list", "kaun available hai",
        "see labourers", "show me workers", "nearby workers"
      ]
    },
    "job_board": {
      "screen": "/jobs",
      "label": "Job Board / Available Jobs",
      "trigger_phrases": [
        "show jobs", "available jobs", "job board", "kaam dhundo",
        "see available work", "job list", "list jobs", "open jobs page",
        "kya kaam hai", "kaam dikhaao"
      ]
    },
    "post_job_form": {
      "screen": "/post-job",
      "label": "Post a Job",
      "trigger_phrases": [
        "post a job", "create job", "add job", "naya job daalo",
        "kaam post karo", "new posting", "add listing",
        "I need workers", "mazdoor chahiye"
      ]
    },
    "worker_register": {
      "screen": "/register-worker",
      "label": "Worker Registration",
      "trigger_phrases": [
        "register as worker", "I am a worker", "sign me up", "worker registration",
        "register me", "mera registration karo", "main mazdoor hoon",
        "worker sign up", "add my profile", "I want jobs"
      ]
    },
    "equipment_rental": {
      "screen": "/equipment",
      "label": "Equipment Rental",
      "trigger_phrases": [
        "rent equipment", "tractor rent", "harvester", "rent machine",
        "equipment", "machine rent karo", "yantra chahiye",
        "tractor chahiye", "combine harvester", "rent tools"
      ]
    },
    "advisory": {
      "screen": "/advisory",
      "label": "Farming Advisory",
      "trigger_phrases": [
        "farming advice", "crop advice", "what to plant", "pest problem",
        "advisory", "salah chahiye", "kis samay bona hai",
        "kheti ki jankari", "kya lagaana chahiye", "disease in crop",
        "soil advice", "weather tips"
      ]
    },
    "my_bookings": {
      "screen": "/bookings",
      "label": "My Bookings / Applications",
      "trigger_phrases": [
        "my bookings", "my applications", "job status", "check status",
        "meri booking", "koi apply hua", "did anyone apply",
        "application status", "booking history", "my requests"
      ]
