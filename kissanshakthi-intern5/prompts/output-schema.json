{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kissanshakthi-intent-parser-output-v1",
  "title": "KissanShakthi AI Intent Parser — Output Schema",
  "description": "Day 4–5 Deliverable. Enforced JSON output schema for all Gemini intent parser responses. Frontend uses this to auto-fill forms and route navigation.",
  "type": "object",
  "required": ["intent", "confidence", "variables", "routing", "fallback", "raw_input"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "POST_JOB",
        "SEARCH_WORKERS",
        "REGISTER_WORKER",
        "VIEW_LISTINGS",
        "CHECK_STATUS",
        "NAVIGATE",
        "EQUIPMENT_RENT",
        "ADVISORY",
        "UNKNOWN"
      ],
      "description": "Classified intent from voice input"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "AI confidence score for intent classification"
    },
    "variables": {
      "type": "object",
      "description": "Extracted structured variables from voice input",
      "required": [
        "crop_type",
        "worker_count",
        "start_date",
        "end_date",
        "duration_days",
        "location",
        "wage_per_day",
        "worker_skill",
        "equipment_type",
        "navigate_target",
        "query_text"
      ],
      "properties": {
        "crop_type": {
          "type": ["string", "null"],
          "description": "Normalized crop name in English lowercase"
        },
        "worker_count": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 500,
          "description": "Number of workers needed or available"
        },
        "start_date": {
          "type": ["string", "null"],
          "description": "ISO 8601 date string YYYY-MM-DD or relative phrase if unresolvable"
        },
        "end_date": {
          "type": ["string", "null"],
          "description": "ISO 8601 end date or null"
        },
        "duration_days": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Job duration in days"
        },
        "location": {
          "type": ["string", "null"],
          "description": "Village, town, district, or region. Title-cased."
        },
        "wage_per_day": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Daily wage in INR"
        },
        "worker_skill": {
          "type": ["string", "null"],
          "enum": [
            "general_labor",
            "tractor_operator",
            "manual_harvesting",
            "pesticide_sprayer",
            "irrigation_worker",
            "planting_worker",
            "sorting_worker",
            null
          ],
          "description": "Specific skill category required"
        },
        "equipment_type": {
          "type": ["string", "null"],
          "description": "Type of farming equipment referenced"
        },
        "navigate_target": {
          "type": ["string", "null"],
          "enum": [
            "home",
            "worker_list",
            "job_board",
            "post_job_form",
            "worker_register",
            "equipment_rental",
            "advisory",
            "my_bookings",
            "profile",
            null
          ],
          "description": "Target screen for NAVIGATE intents"
        },
        "query_text": {
          "type": ["string", "null"],
          "description": "Free-form query for ADVISORY or ambiguous intents"
        }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "description": "Frontend routing and form prefill data",
      "required": ["screen", "prefill"],
      "properties": {
        "screen": {
          "type": "string",
          "description": "Frontend route path to navigate to",
          "examples": ["/post-job", "/workers", "/jobs", "/register-worker", "/", "/equipment", "/advisory", "/bookings"]
        },
        "prefill": {
          "type": "object",
          "description": "Frontend form field prefill map. Keys match React form state property names used by Intern 1.",
          "properties": {
            "cropType": { "type": ["string", "null"] },
            "workersNeeded": { "type": ["integer", "null"] },
            "startDate": { "type": ["string", "null"] },
            "endDate": { "type": ["string", "null"] },
            "durationDays": { "type": ["integer", "null"] },
            "location": { "type": ["string", "null"] },
            "wagePerDay": { "type": ["integer", "null"] },
            "workerSkill": { "type": ["string", "null"] },
            "equipmentType": { "type": ["string", "null"] },
            "searchQuery": { "type": ["string", "null"] }
          }
        }
      }
    },
    "fallback": {
      "type": "object",
      "description": "Fallback state when intent is unclear or critical variables are missing",
      "required": ["triggered", "missing_fields", "clarification_prompt"],
      "properties": {
        "triggered": {
          "type": "boolean",
          "description": "True if fallback mode activated"
        },
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of critical variable keys that are null/missing"
        },
        "clarification_prompt": {
          "type": ["string", "null"],
          "description": "Bilingual Hindi-English prompt displayed to farmer asking for clarification"
        }
      }
    },
    "raw_input": {
      "type": "string",
      "description": "The original transcribed voice input passed to the parser"
    },
    "metadata": {
      "type": "object",
      "description": "Optional call metadata for logging/audit",
      "properties": {
        "parser_version": { "type": "string", "default": "1.0.0" },
        "model_used": { "type": "string", "default": "gemini-1.5-flash" },
        "timestamp": { "type": "string", "description": "ISO 8601 UTC timestamp" },
        "processing_ms": { "type": "integer", "description": "Parser latency in milliseconds" }
      }
    }
  },
  "additionalProperties": false,

  "_route_map_reference": {
    "description": "Canonical screen route map for routing.screen values",
    "POST_JOB": "/post-job",
    "SEARCH_WORKERS": "/workers",
    "REGISTER_WORKER": "/register-worker",
    "VIEW_LISTINGS": "/jobs",
    "CHECK_STATUS": "/bookings",
    "NAVIGATE": "dynamic — use navigate_target to resolve",
    "EQUIPMENT_RENT": "/equipment",
    "ADVISORY": "/advisory",
    "UNKNOWN": "/home"
  }
}
